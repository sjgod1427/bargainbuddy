# ── Required ────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Push notifications (optional but recommended) ────────────────────────────
# Sign up at https://pushover.net — free for 30 days, then ~$5 one-time
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token

# ── HuggingFace ──────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token
HF_DATASET_NAME=sjgod1247/items_lite
HF_SPLIT=train
MAX_ITEMS=20000

# ── Modal (fine-tuned specialist model) ──────────────────────────────────────
# Deploy with: modal deploy modal_app.py
# Then paste the printed endpoint URL here:
MODAL_ENDPOINT_URL=https://your-workspace--bargainbuddy-pricer-price.modal.run

# ── Preprocessor model override (optional) ───────────────────────────────────
# Defaults to groq/llama-3.1-8b-instant — change to any LiteLLM-compatible model
# PRICER_PREPROCESSOR_MODEL=groq/llama-3.3-70b-versatile
# PRICER_PREPROCESSOR_MODEL=ollama/llama3.2
